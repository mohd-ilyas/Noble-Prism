DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@[HOST]:5432/postgres
ENVIRONMENT=production
CORS_ORIGINS=https://your-frontend.onrender.com
VELOCITY_WINDOW_SECONDS=120
VELOCITY_MAX_TRANSACTIONS=20
KILL_SWITCH_RISK_THRESHOLD=0.85
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3
OPENROUTER_TIMEOUT_SECONDS=12
OPENROUTER_MAX_RETRIES=2
OPENROUTER_CACHE_TTL_SECONDS=300
